# ElevenLabs API Key (from https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=your_api_key_here

# SIP Trunk Credentials (used for digest auth with ElevenLabs)
SIP_USERNAME=sip-client
SIP_PASSWORD=change-this-password

# Phone numbers (arbitrary identifiers for SIP trunk)
AGENT_A_NUMBER=+10000000001
AGENT_B_NUMBER=+10000000002

# Local network settings
LOCAL_IP=0.0.0.0
LOCAL_SIP_PORT=5060
LOCAL_RTP_PORT=10000

# ElevenLabs SIP endpoint
ELEVENLABS_SIP_HOST=sip.rtc.elevenlabs.io
ELEVENLABS_SIP_PORT=5060

# Agent A voice (ElevenLabs voice ID - default: Rachel)
AGENT_A_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Agent B voice (ElevenLabs voice ID - default: Domi)
AGENT_B_VOICE_ID=AZnzlk1XvdvUeBnXmlld
